31Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"Draw (sol);","key":"hSjwkPK24F"},{"type":"outputs","id":"SLpW0elgosICxHrNVz0fj","children":[],"key":"NfUa85JVg1"}],"key":"tVPyAjCA4v"},{"type":"block","kind":"notebook-code","data":{"execution":{"iopub.execute_input":"2026-06-12T09:24:42.412729Z","iopub.status.busy":"2026-06-12T09:24:42.412640Z","iopub.status.idle":"2026-06-12T09:24:46.800815Z","shell.execute_reply":"2026-06-12T09:24:46.800268Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"# mesh = Mesh(OCCGeometry(sol).GenerateMesh(maxh=1))\nmesh = sol.GenerateMesh(maxh=1)\n\nmesh.ne","key":"VYXphHJqhr"},{"type":"outputs","id":"6iLpxXnOL2TSbx_pU_byg","children":[],"key":"d5TA8aNNXX"}],"key":"hu84GIqGVB"},{"type":"block","kind":"notebook-code","data":{"execution":{"iopub.execute_input":"2026-06-12T09:24:46.802092Z","iopub.status.busy":"2026-06-12T09:24:46.802002Z","iopub.status.idle":"2026-06-12T09:24:47.303006Z","shell.execute_reply":"2026-06-12T09:24:47.302472Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"Draw (mesh);","key":"XpJvJ2ATFS"},{"type":"outputs","id":"Rfzk-4LcJBYg6zrAxNdES","children":[],"key":"tNDi4aGlw1"}],"key":"unW7PAIA8f"},{"type":"block","kind":"notebook-code","data":{"execution":{"iopub.execute_input":"2026-06-12T09:24:47.316047Z","iopub.status.busy":"2026-06-12T09:24:47.315872Z","iopub.status.idle":"2026-06-12T09:24:52.553562Z","shell.execute_reply":"2026-06-12T09:24:52.553106Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"E, nu = 210, 0.2\nmu  = E / 2 / (1+nu)\nlam = E * nu / ((1+nu)*(1-2*nu))\n\nforce = CF( (1,0,0) )\n\n\ndef Stress(strain):\n    return 2*mu*strain + lam*Trace(strain)*Id(3)    \n\nfes = VectorH1(mesh, order=2, dirichlet=\"left\")\nu,v = fes.TnT()\ngfu = GridFunction(fes)\n\nwith TaskManager():\n    a = BilinearForm(InnerProduct(Stress(Sym(Grad(u))), Sym(Grad(v))).Compile()*dx)\n    a.Assemble()\n    inv = a.mat.Inverse(freedofs=fes.FreeDofs(), inverse=\"sparsecholesky\")\n    f = LinearForm(force*v*ds(\"right\")).Assemble()\n    \ngfu = GridFunction(fes)\ngfu.vec.data = inv * f.vec\n\nDraw (gfu);","key":"YkyYgRqIpR"},{"type":"outputs","id":"YZ1UVO07uhaYZY-CrU3qm","children":[],"key":"MQIgotfNZo"}],"key":"nSA7HhfT5i"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"observe the limits of geometrically linearized elasticity","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AiRkAG9ZUw"}],"key":"lYC933zXIl"}],"key":"MVPqEgK8i2"}],"key":"YTuDUNTVdH"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Twisted beam","url":"/unit1/twisted","group":"Elasticity"},"next":{"title":"Isoparametric Elements","url":"/unit1/isoparametric","group":"Elasticity"}}},"domain":"http://localhost:3000"}