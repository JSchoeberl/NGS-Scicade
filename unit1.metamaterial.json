{"version":3,"kind":"Notebook","sha256":"e6c63a5ecd4d520722103146884106418c353c4c639f946e873c9918e43465c5","slug":"unit1.metamaterial","location":"/unit1/metamaterial.ipynb","dependencies":[],"frontmatter":{"title":"Meta-material with negative Poisson ratio \\nu","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Joachim Schöberl","given":"Joachim","family":"Schöberl"},"name":"Joachim Schöberl","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/JSchoeberl/ESI-Elasticity-Geometry-NGSolve","copyright":"2026","numbering":{"title":{"offset":2}},"source_url":"https://github.com/JSchoeberl/ESI-Elasticity-Geometry-NGSolve/blob/main/unit1/metamaterial.ipynb","edit_url":"https://github.com/JSchoeberl/ESI-Elasticity-Geometry-NGSolve/edit/main/unit1/metamaterial.ipynb","exports":[{"format":"ipynb","filename":"metamaterial.ipynb","url":"/NGS-Scicade//build/metamaterial-69e034dcca4e25b8f699356507cf9301.ipynb"}]},"widgets":{"application/vnd.jupyter.widget-state+json":{"state":{},"version_major":2,"version_minor":0}},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"thanks to Sebastian Hirnschall","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MV1fmf9sr8"}],"key":"JOohjYkU5M"}],"key":"o2CI3XDOVv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from netgen.occ import *\nfrom ngsolve import *\nfrom ngsolve.webgui import Draw","key":"jTk6GBlMkG"},{"type":"outputs","id":"lj6TKUoUDoixtWteew60K","children":[],"key":"OsNtYKDAGN"}],"key":"f0rB4qqqXO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"t=.5\nw=3.5\nh=6\nphi = 30\n\nd = t/sin((90-phi)/360*2*pi)\na = w/tan((90-phi)/360*2*pi)\nwp = MoveTo(w,a).LineTo(0,0).LineTo(0,h).LineTo(w,h-a).Finish().Offset(t/2)\nf1 = Face(wp.Wire())\n\nwp = MoveTo(w-t/2,a+d/2).LineTo(t/2,d/2).LineTo(t/2,h-d/2).LineTo(w-t/2,h-a-d/2).LineTo(w-t/2,h-a+d/2).LineTo(t/2,h+d/2).LineTo(-t/2,h+d/2).LineTo(-t/2,-d/2).LineTo(+t/2,-d/2).LineTo(w-t/2,a-d/2).Close()\nf1=wp.Face()\nDraw(f1);","key":"SKRuZBOja1"},{"type":"outputs","id":"PBM0nQW623wCwvtteI0ES","children":[],"key":"sxCV1RRCzG"}],"key":"e9B5zIptSK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"faces = []\nnx,ny = 9,7\nfor j in range(ny):\n    for i in range(nx):\n        faces.append(f1.Move( (2*i*w,2*j*(h-a),0) ))\n    for i in range(nx):\n        faces.append(f1.Move( ((2*i+1)*w,(2*j+1)*(h-a),0)))\n        \nfaces = sum(faces)","key":"tNXvsAiiw9"},{"type":"outputs","id":"6mEBD3G2BqLDWGUGlmqua","children":[],"key":"zqRcaf0JCG"}],"key":"akqZ2UGoU4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (faces);","key":"XdwJ2LmTo9"},{"type":"outputs","id":"Dbss58QYVE1Tfu-I1dFwz","children":[],"key":"lt2Gbst8g3"}],"key":"MhgNqw3PBt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"wp = MoveTo(3.255,3.5).Rectangle(49.490,43).Reverse().MoveTo(-10,-10).Rectangle(100,100).Face()\ngeo = faces-wp\nDraw(geo);","key":"BXN85RDSre"},{"type":"outputs","id":"-wzgh08c0z1Wv_8uJ1kWx","children":[],"key":"cZzS5JNCQw"}],"key":"ACpppLBqpu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sol = Prism(geo, (0,0,5))","key":"yJwv9KPL7o"},{"type":"outputs","id":"_jPB_mHfxtg4hh7_mFWFD","children":[],"key":"RaGGdmdJje"}],"key":"gQUumRGYhe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"xmin = sol.faces.Min(X).center[0]\nxmax = sol.faces.Max(X).center[0]\nprint (\"xmin/max =\", xmin, xmax)\n\nsol.faces[X<xmin+1e-4].name = \"left\"\nsol.faces[X>xmax-1e-4].name = \"right\"","key":"FZRNtLz9Md"},{"type":"outputs","id":"e07u5pzxwGopZ1C78KATy","children":[],"key":"zV6R5GlAYm"}],"key":"wPujUbrO3i"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (sol);","key":"uVAYdEYR1t"},{"type":"outputs","id":"pAmkg2qJJXP_08GQFyZAM","children":[],"key":"NAb1yP6fr3"}],"key":"jFmgfbFISI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mesh = Mesh(OCCGeometry(sol).GenerateMesh(maxh=1))\nmesh = sol.GenerateMesh(maxh=1)\n\nmesh.ne","key":"bD4gUNE78i"},{"type":"outputs","id":"Ma9I9WrBL0CybtOXuuC6A","children":[],"key":"D8aa0F3qYN"}],"key":"kFBFCOon1n"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (mesh);","key":"rXCs6FCIGJ"},{"type":"outputs","id":"3nSHUoku3gL0N11BhLTSR","children":[],"key":"oL3vMkLpxK"}],"key":"uuDMRDnWE0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"E, nu = 210, 0.2\nmu  = E / 2 / (1+nu)\nlam = E * nu / ((1+nu)*(1-2*nu))\n\nforce = CF( (1,0,0) )\n\n\ndef Stress(strain):\n    return 2*mu*strain + lam*Trace(strain)*Id(3)    \n\nfes = VectorH1(mesh, order=2, dirichlet=\"left\")\nu,v = fes.TnT()\ngfu = GridFunction(fes)\n\nwith TaskManager():\n    a = BilinearForm(InnerProduct(Stress(Sym(Grad(u))), Sym(Grad(v))).Compile()*dx)\n    a.Assemble()\n    inv = a.mat.Inverse(freedofs=fes.FreeDofs(), inverse=\"sparsecholesky\")\n    f = LinearForm(force*v*ds(\"right\")).Assemble()\n    \ngfu = GridFunction(fes)\ngfu.vec.data = inv * f.vec\n\nDraw (gfu);","key":"kyv7WN6ob0"},{"type":"outputs","id":"E1lPSJniotD4wwuSecGNz","children":[],"key":"fHhGEPQta0"}],"key":"hfq94lkkEa"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"observe the limits of geometrically linearized elasticity","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OoFTyDb5RQ"}],"key":"ADym0sDGyU"}],"key":"Grlz2yC6tz"}],"key":"XNAI8sFYga"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Twisted beam","url":"/unit1/twisted","group":"Elasticity"},"next":{"title":"Isoparametric Elements","url":"/unit1/isoparametric","group":"Elasticity"}}},"domain":"http://localhost:3000"}