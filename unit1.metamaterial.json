en":[{"type":"code","lang":"python","executable":true,"value":"t=.5\nw=3.5\nh=6\nphi = 30\n\nd = t/sin((90-phi)/360*2*pi)\na = w/tan((90-phi)/360*2*pi)\nwp = MoveTo(w,a).LineTo(0,0).LineTo(0,h).LineTo(w,h-a).Finish().Offset(t/2)\nf1 = Face(wp.Wire())\n\nwp = MoveTo(w-t/2,a+d/2).LineTo(t/2,d/2).LineTo(t/2,h-d/2).LineTo(w-t/2,h-a-d/2).LineTo(w-t/2,h-a+d/2).LineTo(t/2,h+d/2).LineTo(-t/2,h+d/2).LineTo(-t/2,-d/2).LineTo(+t/2,-d/2).LineTo(w-t/2,a-d/2).Close()\nf1=wp.Face()\nDraw(f1);","key":"C4j6w0urDp"},{"type":"outputs","id":"RsinorhAg71zXkkeySyO4","children":[],"key":"vTiilqTk7s"}],"key":"poBFU7PkcI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"faces = []\nnx,ny = 9,7\nfor j in range(ny):\n    for i in range(nx):\n        faces.append(f1.Move( (2*i*w,2*j*(h-a),0) ))\n    for i in range(nx):\n        faces.append(f1.Move( ((2*i+1)*w,(2*j+1)*(h-a),0)))\n        \nfaces = sum(faces)","key":"n3bkAi9eSH"},{"type":"outputs","id":"w1p0NirHVuG0iq_CnRYpT","children":[],"key":"jM0SZIlGH6"}],"key":"Ek83JykTjj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (faces);","key":"bAGnDzdr8q"},{"type":"outputs","id":"LSLun-2w9kn4-3BsqDiKf","children":[],"key":"GJyQzd2vos"}],"key":"bw06vJYEbh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"wp = MoveTo(3.255,3.5).Rectangle(49.490,43).Reverse().MoveTo(-10,-10).Rectangle(100,100).Face()\ngeo = faces-wp\nDraw(geo);","key":"PoNG0NBLiF"},{"type":"outputs","id":"tuf0fMmx6_AZkpDkKGko8","children":[],"key":"SfYDZO0TCZ"}],"key":"qi2dzVsrYk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sol = Prism(geo, (0,0,5))","key":"WYLTbJAYSq"},{"type":"outputs","id":"NOs_DhlxKkOf0L3w8pvcM","children":[],"key":"BBW8i7Ynw1"}],"key":"wKm5XXz11b"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"xmin = sol.faces.Min(X).center[0]\nxmax = sol.faces.Max(X).center[0]\nprint (\"xmin/max =\", xmin, xmax)\n\nsol.faces[X<xmin+1e-4].name = \"left\"\nsol.faces[X>xmax-1e-4].name = \"right\"","key":"CQJ583fpzF"},{"type":"outputs","id":"IJu1cFDdTraBYRu9KWoBa","children":[],"key":"PQIp3hXZ79"}],"key":"pgRhHV7S5O"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (sol);","key":"i2k9r22NBf"},{"type":"outputs","id":"g7I5ShllcLL_vMN0dINTV","children":[],"key":"Q1vf7QBRBz"}],"key":"U3n3Bp2V4p"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mesh = Mesh(OCCGeometry(sol).GenerateMesh(maxh=1))\nmesh = sol.GenerateMesh(maxh=1)\n\nmesh.ne","key":"yekZsLW77T"},{"type":"outputs","id":"-9xZdsybX32dwwsellye7","children":[],"key":"yVEvprs7Zy"}],"key":"r9WTaJoF3H"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (mesh);","key":"vUCTBUzCkk"},{"type":"outputs","id":"01mhkaeFhks-QdJX5lnJ-","children":[],"key":"NNgwLPjZQB"}],"key":"vS6BQrfxIv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"E, nu = 210, 0.2\nmu  = E / 2 / (1+nu)\nlam = E * nu / ((1+nu)*(1-2*nu))\n\nforce = CF( (1,0,0) )\n\n\ndef Stress(strain):\n    return 2*mu*strain + lam*Trace(strain)*Id(3)    \n\nfes = VectorH1(mesh, order=2, dirichlet=\"left\")\nu,v = fes.TnT()\ngfu = GridFunction(fes)\n\nwith TaskManager():\n    a = BilinearForm(InnerProduct(Stress(Sym(Grad(u))), Sym(Grad(v))).Compile()*dx)\n    a.Assemble()\n    inv = a.mat.Inverse(freedofs=fes.FreeDofs(), inverse=\"sparsecholesky\")\n    f = LinearForm(force*v*ds(\"right\")).Assemble()\n    \ngfu = GridFunction(fes)\ngfu.vec.data = inv * f.vec\n\nDraw (gfu);","key":"hFK89kUiBa"},{"type":"outputs","id":"Prva8DEciTkAIZxQ5Lb9w","children":[],"key":"mgDg5nstAV"}],"key":"va3WQaor4B"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"observe the limits of geometrically linearized elasticity","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aTD5GLZZVg"}],"key":"iD7ZI1fyss"}],"key":"VvY9xyNkGR"}],"key":"gK3TbWeVvo"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Twisted beam","url":"/unit1/twisted","group":"Elasticity"},"next":{"title":"Isoparametric Elements","url":"/unit1/isoparametric","group":"Elasticity"}}},"domain":"http://localhost:3000"}