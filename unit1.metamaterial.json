code","children":[{"type":"code","lang":"python","executable":true,"value":"t=.5\nw=3.5\nh=6\nphi = 30\n\nd = t/sin((90-phi)/360*2*pi)\na = w/tan((90-phi)/360*2*pi)\nwp = MoveTo(w,a).LineTo(0,0).LineTo(0,h).LineTo(w,h-a).Finish().Offset(t/2)\nf1 = Face(wp.Wire())\n\nwp = MoveTo(w-t/2,a+d/2).LineTo(t/2,d/2).LineTo(t/2,h-d/2).LineTo(w-t/2,h-a-d/2).LineTo(w-t/2,h-a+d/2).LineTo(t/2,h+d/2).LineTo(-t/2,h+d/2).LineTo(-t/2,-d/2).LineTo(+t/2,-d/2).LineTo(w-t/2,a-d/2).Close()\nf1=wp.Face()\nDraw(f1);","key":"rQqcEZ1mo9"},{"type":"outputs","id":"X6DkgzZ2ug0pbTy2Wf4c3","children":[],"key":"JURvHudvj9"}],"key":"a3M6xNvvMm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"faces = []\nnx,ny = 9,7\nfor j in range(ny):\n    for i in range(nx):\n        faces.append(f1.Move( (2*i*w,2*j*(h-a),0) ))\n    for i in range(nx):\n        faces.append(f1.Move( ((2*i+1)*w,(2*j+1)*(h-a),0)))\n        \nfaces = sum(faces)","key":"TPK57THz2N"},{"type":"outputs","id":"TK5ufOzpbmAevHSwetBbL","children":[],"key":"wr2gjfiwFp"}],"key":"W9TS3HpuhD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (faces);","key":"vI504QTaA6"},{"type":"outputs","id":"nuimsW7oKRzTaEWm5uscZ","children":[],"key":"asGwzo66nO"}],"key":"jAQnNSFeuq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"wp = MoveTo(3.255,3.5).Rectangle(49.490,43).Reverse().MoveTo(-10,-10).Rectangle(100,100).Face()\ngeo = faces-wp\nDraw(geo);","key":"Gsxz3EArFk"},{"type":"outputs","id":"NS7BBqctIzUffNQrCKA3z","children":[],"key":"Vxme2ZLiuC"}],"key":"Q69KKhuy3u"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sol = Prism(geo, (0,0,5))","key":"dUnjkjWVMt"},{"type":"outputs","id":"aFSdcbzjgtiyovvRlKHX8","children":[],"key":"DgHDRvDJ21"}],"key":"iLM9n7FxcG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"xmin = sol.faces.Min(X).center[0]\nxmax = sol.faces.Max(X).center[0]\nprint (\"xmin/max =\", xmin, xmax)\n\nsol.faces[X<xmin+1e-4].name = \"left\"\nsol.faces[X>xmax-1e-4].name = \"right\"","key":"xhJhostUBP"},{"type":"outputs","id":"EsFI9Crdoigq5jn90bKQa","children":[],"key":"ahRxNf6T6H"}],"key":"WIH1Htp0hu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (sol);","key":"yvZrxPdHVi"},{"type":"outputs","id":"_LWnauC-uLPTUtLNaHEfW","children":[],"key":"GyIv3aek6o"}],"key":"cIXwT4ibvA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mesh = Mesh(OCCGeometry(sol).GenerateMesh(maxh=1))\nmesh = sol.GenerateMesh(maxh=1)\n\nmesh.ne","key":"tu3yMdtS1j"},{"type":"outputs","id":"PImRCVr4VqYlij5QqLxL5","children":[],"key":"BGS21PSgFc"}],"key":"vzP8WqxW4M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (mesh);","key":"LydHtSVquN"},{"type":"outputs","id":"T3LtcGCen_ER83O91shrz","children":[],"key":"hFSWJEYjPl"}],"key":"DYl8v6henI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"E, nu = 210, 0.2\nmu  = E / 2 / (1+nu)\nlam = E * nu / ((1+nu)*(1-2*nu))\n\nforce = CF( (1,0,0) )\n\n\ndef Stress(strain):\n    return 2*mu*strain + lam*Trace(strain)*Id(3)    \n\nfes = VectorH1(mesh, order=2, dirichlet=\"left\")\nu,v = fes.TnT()\ngfu = GridFunction(fes)\n\nwith TaskManager():\n    a = BilinearForm(InnerProduct(Stress(Sym(Grad(u))), Sym(Grad(v))).Compile()*dx)\n    a.Assemble()\n    inv = a.mat.Inverse(freedofs=fes.FreeDofs(), inverse=\"sparsecholesky\")\n    f = LinearForm(force*v*ds(\"right\")).Assemble()\n    \ngfu = GridFunction(fes)\ngfu.vec.data = inv * f.vec\n\nDraw (gfu);","key":"nLBbhLaviy"},{"type":"outputs","id":"oxNz0Phj6x_8WRGbPY4yN","children":[],"key":"iiE72BVkOh"}],"key":"hVIL0jTI3r"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"observe the limits of geometrically linearized elasticity","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lqA9CBC7Fv"}],"key":"wqMAGYswmw"}],"key":"bMsngM9Puk"}],"key":"wMvUUdTn6s"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Twisted beam","url":"/unit1/twisted","group":"Elasticity"},"next":{"title":"Isoparametric Elements","url":"/unit1/isoparametric","group":"Elasticity"}}},"domain":"http://localhost:3000"}