code","children":[{"type":"code","lang":"python","executable":true,"value":"t=.5\nw=3.5\nh=6\nphi = 30\n\nd = t/sin((90-phi)/360*2*pi)\na = w/tan((90-phi)/360*2*pi)\nwp = MoveTo(w,a).LineTo(0,0).LineTo(0,h).LineTo(w,h-a).Finish().Offset(t/2)\nf1 = Face(wp.Wire())\n\nwp = MoveTo(w-t/2,a+d/2).LineTo(t/2,d/2).LineTo(t/2,h-d/2).LineTo(w-t/2,h-a-d/2).LineTo(w-t/2,h-a+d/2).LineTo(t/2,h+d/2).LineTo(-t/2,h+d/2).LineTo(-t/2,-d/2).LineTo(+t/2,-d/2).LineTo(w-t/2,a-d/2).Close()\nf1=wp.Face()\nDraw(f1);","key":"q3VULSW6hd"},{"type":"outputs","id":"chKtARJkpOS6JDpzwjUOy","children":[],"key":"wqPE6Pb1sV"}],"key":"KxIhE89Gtp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"faces = []\nnx,ny = 9,7\nfor j in range(ny):\n    for i in range(nx):\n        faces.append(f1.Move( (2*i*w,2*j*(h-a),0) ))\n    for i in range(nx):\n        faces.append(f1.Move( ((2*i+1)*w,(2*j+1)*(h-a),0)))\n        \nfaces = sum(faces)","key":"q0Gd4a2QgE"},{"type":"outputs","id":"oM3K_92wjztZ_lfLpFFSw","children":[],"key":"CLaviMUpmh"}],"key":"UigLJvHyt0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (faces);","key":"MkGmkP2pWW"},{"type":"outputs","id":"eKUF6NMA4OLu15MT29nzN","children":[],"key":"sscR2xHxua"}],"key":"o7m5icH0nz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"wp = MoveTo(3.255,3.5).Rectangle(49.490,43).Reverse().MoveTo(-10,-10).Rectangle(100,100).Face()\ngeo = faces-wp\nDraw(geo);","key":"Pdj4UE0w38"},{"type":"outputs","id":"bcLT70_eIzJfx_-EH7WGi","children":[],"key":"LlB9Fw4SFN"}],"key":"o8ztHwJQpk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sol = Prism(geo, (0,0,5))","key":"zIvXcA3XCA"},{"type":"outputs","id":"zUwrzymN4TPptlpf_xHqE","children":[],"key":"b0vEf0t67E"}],"key":"b0arLmPdxm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"xmin = sol.faces.Min(X).center[0]\nxmax = sol.faces.Max(X).center[0]\nprint (\"xmin/max =\", xmin, xmax)\n\nsol.faces[X<xmin+1e-4].name = \"left\"\nsol.faces[X>xmax-1e-4].name = \"right\"","key":"U8TSAn8VsH"},{"type":"outputs","id":"X22e_3OOj-dqbYJS26jY7","children":[],"key":"uCEYS72cV6"}],"key":"Tu7uo7AGZg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (sol);","key":"KoOKP1CQjk"},{"type":"outputs","id":"G7ujiIa9oRg94KCI9QRzA","children":[],"key":"P8Sl9fNX3u"}],"key":"w7Yfdy3cDx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mesh = Mesh(OCCGeometry(sol).GenerateMesh(maxh=1))\nmesh = sol.GenerateMesh(maxh=1)\n\nmesh.ne","key":"wlHKUCAxSU"},{"type":"outputs","id":"G_-THgmHHBUJercAKPqQB","children":[],"key":"QEawJYQJWy"}],"key":"LYUWX1CknX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (mesh);","key":"maIi3RZk40"},{"type":"outputs","id":"jEdICZA8vfobyYGbMdfyg","children":[],"key":"Z4usfvfPNn"}],"key":"jmp2Hy1Gm1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"E, nu = 210, 0.2\nmu  = E / 2 / (1+nu)\nlam = E * nu / ((1+nu)*(1-2*nu))\n\nforce = CF( (1,0,0) )\n\n\ndef Stress(strain):\n    return 2*mu*strain + lam*Trace(strain)*Id(3)    \n\nfes = VectorH1(mesh, order=2, dirichlet=\"left\")\nu,v = fes.TnT()\ngfu = GridFunction(fes)\n\nwith TaskManager():\n    a = BilinearForm(InnerProduct(Stress(Sym(Grad(u))), Sym(Grad(v))).Compile()*dx)\n    a.Assemble()\n    inv = a.mat.Inverse(freedofs=fes.FreeDofs(), inverse=\"sparsecholesky\")\n    f = LinearForm(force*v*ds(\"right\")).Assemble()\n    \ngfu = GridFunction(fes)\ngfu.vec.data = inv * f.vec\n\nDraw (gfu);","key":"nM34IbIwhy"},{"type":"outputs","id":"IWbemQyNO_2XFkQOSVsC6","children":[],"key":"knu85Z6VrS"}],"key":"Lc4bmhOrkH"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"observe the limits of geometrically linearized elasticity","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HXkixpjuzT"}],"key":"mktweWc9ue"}],"key":"SyJaflsHPJ"}],"key":"NiE5lc1Q55"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Twisted beam","url":"/unit1/twisted","group":"Elasticity"},"next":{"title":"Isoparametric Elements","url":"/unit1/isoparametric","group":"Elasticity"}}},"domain":"http://localhost:3000"}