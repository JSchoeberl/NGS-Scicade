"}],"key":"XEscDRMchL"},{"type":"block","kind":"notebook-code","data":{"execution":{"iopub.execute_input":"2026-06-12T09:23:30.168133Z","iopub.status.busy":"2026-06-12T09:23:30.168064Z","iopub.status.idle":"2026-06-12T09:23:30.171544Z","shell.execute_reply":"2026-06-12T09:23:30.171058Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"fes = VectorH1(mesh, order=3, dirichlet=\"left\")\nu,v = fes.TnT()\n\ngfu = GridFunction(fes)\ngfv = GridFunction(fes)\ngfa = GridFunction(fes)\ngfuold = GridFunction(fes)\ngfvold = GridFunction(fes)\ngfaold = GridFunction(fes)\n\nbfa = BilinearForm(fes)\nbfa += Variation(NeoHooke(C(u))*dx)\n\nvel_new = 2/tau * (u-gfuold) - gfvold\nacc_new = 2/tau * (vel_new-gfvold) - gfaold\n\nbfa += acc_new*v*dx\nbfa += -force*v*dx","key":"geYbuWEeS3"},{"type":"outputs","id":"_B-MKHQ8t6aG8TNJLLs8O","children":[],"key":"eR0IPTHxEq"}],"key":"U4Ajs5ZmUK"},{"type":"block","kind":"notebook-code","data":{"execution":{"iopub.execute_input":"2026-06-12T09:23:30.172825Z","iopub.status.busy":"2026-06-12T09:23:30.172756Z","iopub.status.idle":"2026-06-12T09:23:30.174658Z","shell.execute_reply":"2026-06-12T09:23:30.174357Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def MyNewton(a, u, printing=False):\n    for it in range(10):\n        res = a.Apply(gfu.vec)\n        if printing:\n            print (\"it=\", it, \"err=\", Norm(res))\n        a.AssembleLinearization(gfu.vec)\n        inv = a.mat.Inverse(fes.FreeDofs(), inverse=\"sparsecholesky\") \n        gfu.vec.data -= inv*res","key":"exHGswYc7S"},{"type":"outputs","id":"mt0bWBWcTep_FGXI4JlzX","children":[],"key":"Z3NYuLBvnf"}],"key":"W9ATefeL2W"},{"type":"block","kind":"notebook-code","data":{"execution":{"iopub.execute_input":"2026-06-12T09:23:30.176014Z","iopub.status.busy":"2026-06-12T09:23:30.175944Z","iopub.status.idle":"2026-06-12T09:24:16.264244Z","shell.execute_reply":"2026-06-12T09:24:16.263924Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"from ngsolve.solvers import Newton\nsceneu = Draw (gfu, mesh, deformation=True)\nscenev = Draw (gfv, mesh)\nscenea = Draw (gfa, mesh)\n# gfu.vec[:] = 0\nt = 0\nwhile t < tend:\n    t += tau\n    MyNewton(a=bfa, u=gfu, printing=False)\n    # Newton(a=bfa, u=gfu, printing=False, inverse=\"sparsecholesky\")\n\n    gfv.vec[:] = 2/tau * (gfu.vec-gfuold.vec) - gfvold.vec\n    gfa.vec[:] = 2/tau * (gfv.vec-gfvold.vec) - gfaold.vec\n\n    sceneu.Redraw()\n    scenev.Redraw()\n    scenea.Redraw()\n    \n    gfuold.vec[:] = gfu.vec\n    gfvold.vec[:] = gfv.vec\n    gfaold.vec[:] = gfa.vec","key":"c4Dcifd6UQ"},{"type":"outputs","id":"2lhdUqMFaMQCA5zxhdRlq","children":[],"key":"DQWeqqRZl0"}],"key":"DWxTUfnjAn"}],"key":"e3VzTsq5oB"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Isoparametric Elements","url":"/unit1/isoparametric","group":"Elasticity"}}},"domain":"http://localhost:3000"}