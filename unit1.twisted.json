Edition\nby Javier Bonet (Author), Antonio J. Gil (Author), Richard D. Wood (Author)","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"wVfMS7Qldr"}],"urlSource":"https://www.amazon.com/Nonlinear-Mechanics-Finite-Element-Analysis/dp/1107115795/ref=pd_bxgy_thbs_d_sccl_1/144-7614425-7391713?pd_rd_w=CqCvS&content-id=amzn1.sym.c51e3ad7-b551-4b1a-b43c-3cf69addb649&pf_rd_p=c51e3ad7-b551-4b1a-b43c-3cf69addb649&pf_rd_r=9HSD8RKNRHDBSK8B5YKQ&pd_rd_wg=B0gaE&pd_rd_r=5fbf0386-d903-408e-b180-af0fd134e615&pd_rd_i=1107115795&psc=1","key":"lOrejDVElN"}],"key":"iGaxOQLPNX"}],"key":"DTNbWeVNWf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from ngsolve import *\nfrom netgen.occ import *\nfrom ngsolve.webgui import Draw\nimport ipywidgets as widgets\n\nea = { \"euler_angles\" : (-120,70,116) }","key":"xps1XhKxl8"},{"type":"outputs","id":"e-7G_ZKlXV-SSzsYxLEoZ","children":[],"key":"Od6HzEGLFm"}],"key":"BJGnXw783T"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"d = 0.01\nbox = Box ( (-d/2,-d/2,0), (d/2,d/2,0.1) ) + Box( (-d/2, -3*d/2,0.1), (d/2, 3*d/2, 0.1+d) )\nbox.faces.Min(Z).name = \"bottom\"\nbox.faces.Max(Z).name = \"top\"\nDraw (box, **ea);\n\nmesh = Mesh(OCCGeometry(box).GenerateMesh(maxh=0.005))\nDraw (mesh, **ea);","key":"udjC5yClxY"},{"type":"outputs","id":"tN0pJJTh8b_wSB83iKXx4","children":[],"key":"tyO8TQaSl9"}],"key":"zm7MYvfWNQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"E, nu = 210, 0.2\nmu  = E / 2 / (1+nu)\nlam = E * nu / ((1+nu)*(1-2*nu))\n\ndef C(u):\n    F = Id(u.dim) + Grad(u)\n    return F.trans * F\n\ndef NeoHooke (C):\n    # return 0.5*mu*InnerProduct(C-Id(3), C-Id(3))\n    return 0.5*mu*(Trace(C-Id(3)) + 2*mu/lam*Det(C)**(-lam/2/mu)-1)","key":"nYtjvRG39k"},{"type":"outputs","id":"uWfHD0pwXgyq7Y-dihWc1","children":[],"key":"tX25gZG3tn"}],"key":"r6V6v7BT8L"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"A follower load is ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mzzQp7Pi4U"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"rotated","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kbUq8psVyr"}],"key":"iqXsrpaUc5"},{"type":"text","value":" with the deformation gradient ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"v6Em0hkvi7"},{"type":"inlineMath","value":"F = I + \\nabla u","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>F</mi><mo>=</mo><mi>I</mi><mo>+</mo><mi mathvariant=\"normal\">∇</mi><mi>u</mi></mrow><annotation encoding=\"application/x-tex\">F = I + \\nabla u</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.13889em;\">F</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.7667em;vertical-align:-0.0833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">I</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord\">∇</span><span class=\"mord mathnormal\">u</span></span></span></span>","key":"K4CQAEvn2m"},{"type":"text","value":".","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gb84EUQYTM"}],"key":"Ae76uU3mEj"}],"key":"XKU8chWKld"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"loadfactor = Parameter(1)\nforce = loadfactor * CF ( (-y, x, 0) )\n\nfes = H1(mesh, order=3, dirichlet=\"bottom\", dim=mesh.dim)\nu,v = fes.TnT()\n\na = BilinearForm(fes, symmetric=True)\na += Variation(NeoHooke(C(u)).Compile()*dx)\na += ((Id(3)+Grad(u.Trace()))*force)*v*ds(\"top\")\n\ngfu = GridFunction(fes)\ngfu.vec[:] = 0","key":"cRHoRPXTT4"},{"type":"outputs","id":"iASsXr5VqeyhCfCHioffY","children":[],"key":"d6hDmAkG3E"}],"key":"ti5BYeZbQD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"gfu_history = GridFunction(fes, multidim=0)\nscene = Draw (gfu, deformation=True, **ea)\ntw = widgets.Text(value='step = 0')\ndisplay(tw)\n\ngfu.vec[:] = 0\n\nnumsteps = 30\nfor step in range(numsteps):\n    loadfactor.Set(300*step/numsteps)\n    solvers.Newton (a, gfu, printing=False, dampfactor=0.5)\n    scene.Redraw()\n    tw.value = 'step = '+str(step+1)+'/'+str(numsteps)\n    gfu_history.AddMultiDimComponent(gfu.vec)","key":"rQEpKUOWv1"},{"type":"outputs","id":"XbWqIiUEymAN5rPVeo5g3","children":[],"key":"gzQW7N5hEs"}],"key":"xufe4L2knz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Draw (gfu_history, mesh, animate=True, min=0, max=0.04, autoscale=True, deformation=True, **ea);","key":"mZ1kuBAQvZ"},{"type":"outputs","id":"PdAkJN66O06baxuqDmVRN","children":[],"key":"kIDVkVHgRl"}],"key":"bK0fiQUh7b"}],"key":"BtcOtO4whM"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"3D Solid Mechanics","url":"/unit1/elasticity3d","group":"Elasticity"},"next":{"title":"Meta-material with negative Poisson ratio \\nu","short_title":"Meta material","url":"/unit1/metamaterial","group":"Elasticity"}}},"domain":"http://localhost:3000"}